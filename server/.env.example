# Server port (default: 5001)
PORT=5001

# MongoDB connection string (optional — leave empty for local JSON mock DB)
MONGODB_URI=

# REQUIRED — Groq API key from https://console.groq.com (free tier available)
# All AI features (detection, viva, scoring) use live Groq analysis — no mock guesses
GROQ_API_KEY=your_key_from_console.groq.com

# Primary model (default: llama-3.3-70b-versatile) — best quality, uses more daily tokens
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback when primary hits rate limit (smaller, separate quota on free tier)
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

JWT_SECRET=your_super_secret_jwt_key_change_this
TEACHER_USERNAME=admin
TEACHER_PASSWORD=1234
